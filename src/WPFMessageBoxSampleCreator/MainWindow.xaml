<Window
    x:Class="WPFMessageBoxSampleCreator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFMessageBoxSampleCreator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:messagebox="clr-namespace:WPFMessageBoxSampleCreator.Features.MessageBoxSampleCreator"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    Title="WPFMessageBoxSampleCreator"
    Width="800"
    Height="350"
    d:DataContext="{d:DesignInstance local:MainWindowViewModel,
                                     IsDesignTimeCreatable=True}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <messagebox:MessageBoxSampleCreatorViewModel x:Key="MessageBoxSampleCreatorViewModel" />
    </Window.Resources>
    <messagebox:MessageBoxSampleCreatorControl DataContext="{StaticResource MessageBoxSampleCreatorViewModel}" />
</Window>
